{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
        "text": "Producer Price Index Over Time",
        "subtitle": [
            "The graph shows how Malaysia’s food producer prices shifted from 1991 to 2022, with sharp rises",
            "around 2008 and after 2020. These fluctuations highlight how global crises and local supply",
            "pressures shape food culture, influencing affordability, dietary choices, and everyday meals across the country"
        ],
        "anchor": "start"    
    },
  "width": 650,
  "height": 420,

  "data": {
    "url": "data/producer-prices_mys.csv",
    "format": {"type": "csv"}
  },

  "transform": [
    {
      "filter": {
        "field": "Item",
        "oneOf": [
          "Coarse Grain, Total",
          "Meat, Total",
          "Milk, Total",
          "Vegetables&Melons, Total"
        ]
      }
    },
    {"filter": "datum.Year != '#date+year'"},
    {"calculate": "toNumber(datum.Year)", "as": "YearNum"},
    {"calculate": "toNumber(datum.Value)", "as": "PriceIndex"}
  ],

  "layer": [
    {
      "mark": {"type": "line", "point": true},
      "encoding": {
        "x": {"field": "YearNum", "type": "ordinal", "title": "Year"},
        "y": {"field": "PriceIndex", "type": "quantitative", "title": "Producer Price Index"},
        "color": {"field": "Item", "type": "nominal", "title": "Product Category"},
        "tooltip": [
          {"field": "Item", "type": "nominal"},
          {"field": "YearNum", "type": "ordinal", "title": "Year"},
          {"field": "PriceIndex", "type": "quantitative", "format": ".2f", "title": "PPI"}
        ]
      }
    }
  ]
}