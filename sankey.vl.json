      "transform": [
        {
          "type": "formula",
          "expr": "datum.col0",
          "as": "col0"
        },
        {
          "type": "formula",
          "expr": "datum.col1",
          "as": "col1"
        },
        {
          "type": "formula",
          "expr": "datum.col2",
          "as": "col2"
        },
        {
          "type": "formula",
          "expr": "datum.size",
          "as": "size"
        }
      ]
    },
    {
      "name": "nodesA",
      "source": "rawData",
      "transform": [
        {
          "type": "formula",
          "expr": "datum.col0 + '|' + datum.col1",
          "as": "key"
        },
        {
          "type": "fold",
          "fields": [
            "col0",
            "col1"
          ],
          "as": [
            "stack",
            "grpId"
          ]
        },
        {
          "type": "formula",
          "expr": "datum.stack=='col0' ? datum.col0+' '+datum.col1 : datum.col1+' '+datum.col0",
          "as": "sortField"
        },
        {
          "type": "stack",
          "groupby": [
            "stack"
          ],
          "sort": {
            "field": "sortField",
            "order": "descending"
          },
          "field": "size"
        },
        {
          "type": "formula",
          "expr": "(datum.y0+datum.y1)/2",
          "as": "yc"
        }
      ]
    },
    {
      "name": "groupsA",
      "source": "nodesA",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "stack",
            "grpId"
          ],
          "fields": [
            "size"
          ],
          "ops": [
            "sum"
          ],
          "as": [
            "total"
          ]
        },
        {
          "type": "stack",
          "groupby": [
            "stack"
          ],
          "sort": {
            "field": "grpId",
            "order": "descending"
          },
          "field": "total"
        },
        {
          "type": "formula",
          "expr": "scale('y', datum.y0)",
          "as": "scaledY0"
        },
        {
          "type": "formula",
          "expr": "scale('y', datum.y1)",
          "as": "scaledY1"
        },
        {
          "type": "formula",
          "expr": "datum.stack=='col0'",
          "as": "rightLabel"
        },
        {
          "type": "formula",
          "expr": "datum.total/domain('y')[1]",
          "as": "percentage"
        }
      ]
    },
    {
      "name": "destNodesA",
      "source": "nodesA",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.stack=='col1'"
        }
      ]
    },
    {
      "name": "edgesA",
      "source": "nodesA",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.stack=='col0'"
        },
        {
          "type": "lookup",
          "from": "destNodesA",
          "key": "key",
          "fields": [
            "key"
          ],
          "as": [
            "target"
          ]
        },
        {
          "type": "linkpath",
          "orient": "horizontal",
          "shape": "diagonal",
          "sourceY": {
            "expr": "scale('y', datum.yc)"
          },
          "sourceX": {
            "expr": "scale('x', 'col0') + bandwidth('x')"
          },
          "targetY": {
            "expr": "scale('y', datum.target.yc)"
          },
          "targetX": {
            "expr": "scale('x', 'col1')"
          }
        },
        {
          "type": "formula",
          "expr": "range('y')[0]-scale('y', datum.size)",
          "as": "strokeWidth"
        },
        {
          "type": "formula",
          "expr": "datum.size/domain('y')[1]",
          "as": "percentage"
        }
      ]
    },
    {
      "name": "nodesB",
      "source": "rawData",
      "transform": [
        {
          "type": "formula",
          "expr": "datum.col1 + '|' + datum.col2",
          "as": "key"
        },
        {
          "type": "fold",
          "fields": [
            "col1",
            "col2"
          ],
          "as": [
            "stack",
            "grpId"
          ]
        },
        {
          "type": "formula",
          "expr": "datum.stack=='col1' ? datum.col1+' '+datum.col2 : datum.col2+' '+datum.col1",
          "as": "sortField"
        },
        {
          "type": "stack",
          "groupby": [
            "stack"
          ],
          "sort": {
            "field": "sortField",
            "order": "descending"
          },
          "field": "size"
        },
        {
          "type": "formula",
          "expr": "(datum.y0+datum.y1)/2",
          "as": "yc"
        }
      ]
    },
    {
      "name": "groupsB",
      "source": "nodesB",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "stack",
            "grpId"
          ],
          "fields": [
            "size"
          ],
          "ops": [
            "sum"
          ],
          "as": [
            "total"
          ]
        },
        {
          "type": "stack",
          "groupby": [
            "stack"
          ],
          "sort": {
            "field": "grpId",
            "order": "descending"
          },
          "field": "total"
        },
        {
          "type": "formula",
          "expr": "scale('y', datum.y0)",
          "as": "scaledY0"
        },
        {
          "type": "formula",
          "expr": "scale('y', datum.y1)",
          "as": "scaledY1"
        },
        {
          "type": "formula",
          "expr": "datum.stack=='col1'",
          "as": "rightLabel"
        },
        {
          "type": "formula",
          "expr": "datum.total/domain('y')[1]",
          "as": "percentage"
        }
      ]
    },
    {
      "name": "destNodesB",
      "source": "nodesB",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.stack=='col2'"
        }
      ]
    },
    {
      "name": "edgesB",
      "source": "nodesB",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.stack=='col1'"
        },
        {
          "type": "lookup",
          "from": "destNodesB",
          "key": "key",
          "fields": [
            "key"
          ],
          "as": [
            "target"
          ]
        },
        {
          "type": "linkpath",
          "orient": "horizontal",
          "shape": "diagonal",
          "sourceY": {
            "expr": "scale('y', datum.yc)"
          },
          "sourceX": {
            "expr": "scale('x', 'col1') + bandwidth('x')"
          },
          "targetY": {
            "expr": "scale('y', datum.target.yc)"
          },
          "targetX": {
            "expr": "scale('x', 'col2')"
          }
        },
        {
          "type": "formula",
          "expr": "range('y')[0]-scale('y', datum.size)",
          "as": "strokeWidth"
        },
        {
          "type": "formula",
          "expr": "datum.size/domain('y')[1]",
          "as": "percentage"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "x",
      "type": "band",
      "range": "width",
      "domain": [
        "col0",
        "col1",
        "col2"
      ],
      "paddingOuter": 0.02,
      "paddingInner": 0.82
    },
    {
      "name": "y",
      "type": "linear",
      "range": "height",
      "domain": {
        "fields": [
          {
            "data": "nodesA",
            "field": "y1"
          },
          {
            "data": "nodesB",
            "field": "y1"
          }
        ]
      }
    },
    {
      "name": "colorGender",
      "type": "ordinal",
      "domain": [
        "Female",
        "Male"
      ],
      "range": [
        "#C04E7A",
        "#2E6EB5"
      ]
    },
    {
      "name": "colorMeal",
      "type": "ordinal",
      "domain": [
        "Breakfast",
        "Lunch",
        "Dinner"
      ],
      "range": [
        "#C7762A",
        "#1D7A5A",
        "#4A4AA8"
      ]
    },
    {
      "name": "stackNames",
      "type": "ordinal",
      "domain": [
        "col0",
        "col1",
        "col2"
      ],
      "range": [
        "Gender",
        "Meal Time",
        "Meal Type"
      ]
    }
  ],
  "axes": [
    {
      "orient": "bottom",
      "scale": "x",
      "encode": {
        "labels": {
          "update": {
            "text": {
              "scale": "stackNames",
              "field": "value"
            },
            "fontSize": {
              "value": 14
            },
            "fontWeight": {
              "value": "bold"
            },
            "fill": {
              "value": "#444"
            }
          }
        }
      },
      "ticks": false,
      "domain": false
    }
  ],
  "marks": [
    {
      "type": "path",
      "from": {
        "data": "edgesA"
      },
      "clip": true,
      "encode": {
        "update": {
          "stroke": {
            "scale": "colorGender",
            "field": "col0"
          },
          "strokeWidth": {
            "field": "strokeWidth"
          },
          "path": {
            "field": "path"
          },
          "strokeOpacity": {
            "value": 0.25
          },
          "tooltip": {
            "signal": "datum.col0 + ' \u2192 ' + datum.col1 + ':  ' + datum.size + ' respondents (' + format(datum.percentage,'.1%') + ')'"
          }
        },
        "hover": {
          "strokeOpacity": {
            "value": 0.85
          }
        }
      }
    },
    {
      "type": "path",
      "from": {
        "data": "edgesB"
      },
      "clip": true,
      "encode": {
        "update": {
          "stroke": {
            "scale": "colorMeal",
            "field": "col1"
          },
          "strokeWidth": {
            "field": "strokeWidth"
          },
          "path": {
            "field": "path"
          },
          "strokeOpacity": {
            "value": 0.25
          },
          "tooltip": {
            "signal": "datum.col1 + ' \u2192 ' + datum.col2 + ':  ' + datum.size + ' respondents (' + format(datum.percentage,'.1%') + ')'"
          }
        },
        "hover": {
          "strokeOpacity": {
            "value": 0.85
          }
        }
      }
    },
    {
      "type": "rect",
      "from": {
        "data": "groupsA"
      },
      "encode": {
        "enter": {
          "width": {
            "scale": "x",
            "band": 1
          }
        },
        "update": {
          "x": {
            "scale": "x",
            "field": "stack"
          },
          "y": {
            "field": "scaledY0"
          },
          "y2": {
            "field": "scaledY1"
          },
          "fill": [
            {
              "test": "datum.stack=='col0'",
              "scale": "colorGender",
              "field": "grpId"
            },
            {
              "scale": "colorMeal",
              "field": "grpId"
            }
          ],
          "fillOpacity": {
            "value": 0.8
          },
          "cornerRadius": {
            "value": 3
