{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 650,
    "height": 420,
    "title": {
        "text": "Average Restaurant Ratings by Malaysian State",
        "subtitle": [
            "This shows the average restaurant rating across several states in Malaysia.",
            "This gives us a general idea about where we can find the best food across the country.",
            "Food preference is a subjective matter, but this helps discover new and exciting restaurants."
        ],
        "anchor": "start"    
    },


    "data": {
        "url": "data/malaysia-states.topojson",
        "format": {
        "type": "topojson",
        "feature": "states"
            }
        },
    "transform": [
    {
    "lookup": "properties.Name",
    "from": {
        "data": {
            "url": "data/malaysia_restaurant_ratings.json"
        },
        "key": "State",
        "fields": [
        "average_rating",
        "total_reviews"
                ]
            }
        }
    ],

    "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
        },
    
    "encoding": {
        "color": {
            "field": "average_rating",
            "type": "quantitative",
            "title": "Average Rating",
            "scale": {
            "scheme": "blues"
                }
            },
        "tooltip": [
            {
                "field": "properties.Name",
                "type": "nominal",
                "title": "State"
            },
            {
                "field": "average_rating",
                "type": "quantitative",
                "title": "Average Rating"
            },
            {
                "field":"total_reviews",
                "type": "quantitative",
                "title": "Total Reviews"
            }
        ]
    },

    "projection": {
        "type":"mercator"
    }
}
    
