{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Number of Meals Eaten Per Day"},
  "data": {"url": "data/q_data.csv"},
  "transform": [
    {"calculate": "datum['Q7.No_of_Meals_Per_Day']", "as": "meals_per_day"}
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Total Respondents"
    },
    "y": {
      "field": "meals_per_day",
      "type": "ordinal",
      "title": "No. of Meals Per Day",
      "sort": "ascending"
    }
  }
}